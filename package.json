{
  "name": "opencode-learning-guard",
  "version": "0.2.0",
  "description": "Deterministic enforcement tools for bounded OpenCode memory and managed-skill writes.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./tools": "./src/tools.js",
    "./standalone": "./src/standalone.js"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "skills",
    "self-improvement"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tah10n/opencode-learning-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Tah10n/opencode-learning-guard/issues"
  },
  "homepage": "https://github.com/Tah10n/opencode-learning-guard#readme",
  "license": "MIT",
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "check": "node --check src/index.js && node --check src/tools.js && node --check src/standalone.js",
    "test": "node --test",
    "pack:check": "npm pack --dry-run --json --cache .cache/npm",
    "verify": "npm run check && npm test && npm run pack:check"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.4.7",
    "effect": "4.0.0-beta.48"
  }
}
